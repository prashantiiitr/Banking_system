generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(CUSTOMER)

  refreshToken String?
  accounts Account[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  ADMIN
  BANK_OFFICER
  CUSTOMER
}

model Account {
  id            String        @id @default(uuid())
  accountNumber String        @unique
  balance       Float         @default(0)
  currency      String        @default("INR")
  type          AccountType
  status        AccountStatus @default(PENDING)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  ledgerEntries LedgerEntry[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model LedgerEntry {
  id          String      @id @default(uuid())
  accountId   String
  account     Account     @relation(fields: [accountId], references: [id])
  type        EntryType
  amount      Float
  description String
  createdAt   DateTime    @default(now())
}

model Transaction {
  id                String            @id @default(uuid())

  fromAccountId     String

  toAccountId       String

  amount            Float

  status            TransactionStatus @default(INITIATED)

  description       String?

  idempotencyKey    String            @unique

  createdAt         DateTime          @default(now())

  updatedAt         DateTime          @updatedAt
  transferType TransferType

  referenceNumber String

  remarks String?
}

model Beneficiary {
  id                  String   @id @default(uuid())

  userId              String

  name                String

  bankName            String

  accountNumber       String

  ifscCode            String

  isApproved          Boolean  @default(false)

  approvedAt          DateTime?

  coolingPeriodEndsAt DateTime?

  createdAt           DateTime @default(now())
}
model OtpVerification {
  id         String   @id @default(uuid())

  userId     String

  otp        String

  purpose    OtpPurpose

  verified   Boolean @default(false)

  expiresAt  DateTime

  createdAt  DateTime @default(now())
}

model KYC {
  id          String @id @default(uuid())

  userId      String

  panNumber   String

  aadhaar     String

  address     String

  status      KycStatus @default(PENDING)

  createdAt   DateTime @default(now())
}

model Nominee {
  id          String @id @default(uuid())

  accountId   String

  name        String

  relation    String

  phone       String

  createdAt   DateTime @default(now())
}
enum OtpPurpose {
  LOGIN
  TRANSFER
  PASSWORD_RESET
}

enum TransferType {
  IMPS
  NEFT
  RTGS
}



enum TransactionStatus {
  INITIATED
  PROCESSING
  COMPLETED
  FAILED
  ROLLED_BACK
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AccountType {
  SAVINGS
  CURRENT
}

enum EntryType {
  DEBIT
  CREDIT
}

model Loan {
  id              String       @id @default(uuid())

  userId          String

  amount          Float

  interestRate    Float

  tenureMonths    Int

  monthlyEmi      Float

  status          LoanStatus   @default(PENDING)

  remainingAmount Float

  createdAt       DateTime     @default(now())

  updatedAt       DateTime     @updatedAt
}

enum LoanStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  CLOSED
}

enum AccountStatus {
  PENDING
  ACTIVE
  REJECTED
}
